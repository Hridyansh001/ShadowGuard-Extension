{
  "manifest_version": 3,

  "name": "ShadowGuard",

  "version": "1.0",

  "description": "Prevents sensitive data leakage through AI tools",

  "permissions": [
    "storage"
  ],  
  "host_permissions": [
    "https://gemini.google.com/*",
  "https://chatgpt.com/*",
  "http://localhost:8080/*",
  "https://claude.ai/*",
  "https://github.com/*"       
],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://github.com/*"
      ],

      "js": [
        "content.js"
      ],

      "css": [
        "styles.css"
      ],

      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}